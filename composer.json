{
  "name": "k2gl/enum",
  "description": "PHP BackedEnum spiced with syntactic sugar",
  "homepage": "https://github.com/k2gl/enum",
  "type": "library",
  "license": "MIT",
  "keywords": [
    "php",
    "enum",
    "backedenum"
  ],
  "authors": [
    {
      "name": "Nickolay Harin",
      "email": "l0gic@ya.ru"
    }
  ],
  "support": {
    "issues": "https://github.com/k2gl/enum/issues",
    "source": "https://github.com/k2gl/enum"
  },
  "require": {
    "php": ">=8.1"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.5|^11.0|^12.0",
    "phpstan/phpstan": "^2.1",
    "friendsofphp/php-cs-fixer": "^3.64",
    "k2gl/phpunit-fluent-assertions": "^12"
  },
  "autoload": {
    "psr-4": {
      "K2gl\\Enum\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "K2gl\\Enum\\Tests\\": "tests/"
    }
  },
  "minimum-stability": "stable",
  "scripts": {
    "test": "phpunit",
    "phpstan": "phpstan analyse",
    "cs": "php-cs-fixer fix --dry-run --diff",
    "cs-fix": "php-cs-fixer fix",
    "check": [
      "@test",
      "@phpstan",
      "@cs"
    ]
  }
}
